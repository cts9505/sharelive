# Environment Configuration for ShareLive Backend

# ======================
# Server Configuration
# ======================
NODE_ENV=development
PORT=8080
MAX_TUNNEL_LIFETIME=0
HOST=0.0.0.0
BASE_DOMAIN=sharelive.site
FRONTEND_URL=http://localhost:3000

# ======================
# Database
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/sharelive

# ======================
# CORS Configuration
# ======================
# Comma-separated list of allowed origins
# Note: Variable name is CORS_ORIGIN (not ALLOWED_ORIGINS)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ======================
# Security - Authentication
# ======================
# Set to 'true' to require authentication for tunnel creation (recommended for production)
REQUIRE_AUTH=false

# JWT secret for token signing (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=jTXNFTArYIwEeNg4ALoiENdDI0R+KI9sYwjPwjAITYU=

# ======================
# Security - Tunnel Configuration
# ======================
# Maximum request body size in bytes (default: 10MB)
MAX_REQUEST_SIZE=10485760

# Maximum tunnel lifetime in milliseconds (default: 4 hours = 14400000ms)
MAX_TUNNEL_LIFETIME=0

# Maximum requests per minute per tunnel (default: 100)
TUNNEL_RATE_LIMIT=100

# Enable tunnel access tokens (set to 'true' for additional security)
ENABLE_TUNNEL_TOKENS=false

# ======================
# Email (SMTP) Configuration
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ShareLive <your-email@gmail.com>"

# ======================
# Payment Gateway (Razorpay)
# ======================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ======================
# DNS Management (Cloudflare)
# ======================
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# ======================
# Notes
# ======================
# 1. Never commit .env file to version control
# 2. Copy this file to .env and fill in your actual values
# 3. For production, set REQUIRE_AUTH=true
# 4. Generate a strong JWT_SECRET (min 32 characters)
# 5. Keep all API keys and secrets secure
