generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(uuid()) @map("id")
  email                 String         @unique @map("email")
  passwordHash          String         @map("password_hash")
  
  // Profile Information
  fullName              String?        @map("full_name")
  phoneNumber           String?        @map("phone_number")
  phoneVerified         Boolean        @default(false) @map("phone_verified")
  phoneVerifiedAt       DateTime?      @map("phone_verified_at")
  emailVerified         Boolean        @default(false) @map("email_verified")
  emailVerifiedAt       DateTime?      @map("email_verified_at")
  
  // Address Information
  addressLine1          String?        @map("address_line1")
  addressLine2          String?        @map("address_line2")
  city                  String?        @map("city")
  state                 String?        @map("state")
  country               String?        @map("country")
  postalCode            String?        @map("postal_code")
  
  // Business Information
  occupation            String?        @map("occupation")
  companyName           String?        @map("company_name")
  gstin                 String?        @unique @map("gstin")
  gstinVerified         Boolean        @default(false) @map("gstin_verified")
  
  // Preferences
  newsletterSubscribed  Boolean        @default(false) @map("newsletter_subscribed")
  
  // Onboarding
  onboardingCompleted   Boolean        @default(false) @map("onboarding_completed")
  onboardingStep        Int            @default(0) @map("onboarding_step")
  
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at")
  
  projects              Project[]
  payments              Payment[]
  verificationTokens    VerificationToken[]

  @@map("users")
}

model Project {
  id                   String           @id @default(uuid()) @map("id")
  owner                User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId              String           @map("owner_id")
  subdomain            String           @unique @map("subdomain")
  targetUrl            String           @map("target_url")
  plan                 Plan             @map("plan")
  dnsRecordId          String?          @map("dns_record_id")
  hostingPlatform      HostingPlatform? @map("hosting_platform")
  platformInstructions String?          @map("platform_instructions") @db.Text
  totalVisits          Int              @default(0) @map("total_visits")
  lastVisitedAt        DateTime?        @map("last_visited_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  analytics            Analytics[]

  @@index([subdomain], name: "idx_projects_subdomain")
  @@map("projects")
}

model Analytics {
  id           String   @id @default(uuid()) @map("id")
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String   @map("project_id")
  date         DateTime @map("date") @db.Date
  visits       Int      @default(0) @map("visits")
  uniqueVisits Int      @default(0) @map("unique_visits")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([projectId, date])
  @@index([projectId, date])
  @@map("analytics")
}

enum Plan {
  free_proxy
  paid_direct
}

enum HostingPlatform {
  vercel
  netlify
  render
  railway
  flyio
  heroku
  azure
  cloudflare
  firebase
  other
}

model Coupon {
  id            String        @id @default(uuid()) @map("id")
  code          String        @unique @map("code")
  discountType  String        @map("discount_type") // 'percentage' or 'fixed'
  discountValue Int           @map("discount_value") // percentage (0-100) or fixed amount in paise
  minAmount     Int?          @map("min_amount") // minimum order amount in paise
  maxDiscount   Int?          @map("max_discount") // max discount cap for percentage coupons (in paise)
  usageLimit    Int?          @map("usage_limit") // total usage limit
  usageCount    Int           @default(0) @map("usage_count")
  validFrom     DateTime      @default(now()) @map("valid_from")
  validUntil    DateTime?     @map("valid_until")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  usages        CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid()) @map("id")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId  String   @map("coupon_id")
  userId    String   @map("user_id")
  orderId   String   @map("order_id")
  discount  Int      @map("discount") // actual discount applied in paise
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([couponId, userId, orderId])
  @@index([userId])
  @@index([couponId])
  @@map("coupon_usages")
}

model Payment {
  id                String        @id @default(uuid()) @map("id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String        @map("user_id")
  
  // Razorpay Details
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpaySignature String?       @map("razorpay_signature")
  
  // Payment Details
  amount            Int           @map("amount") // amount in paise
  currency          String        @default("INR") @map("currency")
  status            PaymentStatus @default(pending) @map("status")
  
  // Order Details
  projectId         String?       @map("project_id")
  planType          Plan?         @map("plan_type")
  description       String?       @map("description") @db.Text
  
  // Coupon
  couponCode        String?       @map("coupon_code")
  discountAmount    Int           @default(0) @map("discount_amount") // in paise
  
  // Metadata
  paymentMethod     String?       @map("payment_method")
  failureReason     String?       @map("failure_reason")
  
  // GST Details
  gstAmount         Int?          @map("gst_amount") // in paise
  cgst              Int?          @map("cgst") // in paise
  sgst              Int?          @map("sgst") // in paise
  igst              Int?          @map("igst") // in paise
  
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  completedAt       DateTime?     @map("completed_at")

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payments")
}

model VerificationToken {
  id        String           @id @default(uuid()) @map("id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String           @map("user_id")
  token     String           @unique @map("token")
  type      VerificationType @map("type")
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, type])
  @@index([token])
  @@map("verification_tokens")
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
  cancelled
}

enum VerificationType {
  email
  phone
  password_reset
}

